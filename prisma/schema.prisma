generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
    id       Int    @id @default(autoincrement())
    email    String @unique
    password String
}

model App {
    id           String   @id @default(uuid())
    title        String
    url          String
    description1 String
    description2 String
    image1       String
    image2       String
    color        String
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
}